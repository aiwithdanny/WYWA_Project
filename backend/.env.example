# Backend environment variables
# Copy this file to .env and fill values.

# Neon (PostgreSQL) connection string.
# Example format:
# postgresql://USER:PASSWORD@ep-something-1234567.us-east-2.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL=""

# Server
PORT=5000
NODE_ENV=development

# CORS / Frontend URL
CORS_ORIGIN="http://localhost:3000"

# JWT (used by admin routes)
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# NextAuth secret (if shared with frontend) (optional)
NEXTAUTH_SECRET=""

# Email (Nodemailer + SendGrid)
SENDGRID_API_KEY=""
MAIL_FROM="WYWA <no-reply@wywa.org>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# JazzCash
JAZZCASH_MERCHANT_ID=""
JAZZCASH_STORE_PASSWORD=""
JAZZCASH_API_USERNAME=""
JAZZCASH_API_PASSWORD=""
JAZZCASH_API_BASE_URL=""

